{
  "expo": {
    "name": "bus-connect",
    "slug": "bus-connect",
    "version": "1.0.0",
    "scheme": "bus-connect",
    "plugins": [
      "expo-router",
      "@react-native-community/datetimepicker"
    ],
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#07111f"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.puretechnologies.busconnect"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#07111f"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.puretechnologies.busconnect"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "7c76dfeb-31a9-4139-8f4f-5bc105528a50"
      }
    }
  }
}
